{
  "name": "vehicle-register-system",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx nx serve vehicle-register-system",
    "start:nest-api": "npx nx serve nest-api",
    "build": "npx nx build vehicle-register-system && npm run browser:obfuscator && npx nx build api",
    "server:obfuscator": "javascript-obfuscator ./dist/vehicle-register-system/server --output ./dist/vehicle-register-system/server --config obfuscator.config.json",
    "browser:obfuscator": "javascript-obfuscator ./dist/vehicle-register-system/browser --output ./dist/vehicle-register-system/browser --config obfuscator.config.json",
    "watch": "nx build --watch --configuration development",
    "test": "nx test",
    "serve:app-server": "node dist/vehicle-register-system/server/server.mjs",
    "serve:express-server": "node ./dist/apps/api/main.js",
    "serve:ssr": "npm run build && npx concurrently \"npm run serve:app-server\" \"npm run serve:express-server\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "compodoc": "npx compodoc -p tsconfig.doc.json",
    "compodoc:build": "compodoc -p tsconfig.doc.json",
    "compodoc:build-and-serve": "compodoc -p tsconfig.doc.json -s",
    "compodoc:serve": "compodoc -s"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.11",
    "@angular/common": "^20.3.11",
    "@angular/compiler": "^20.3.11",
    "@angular/core": "^20.3.11",
    "@angular/forms": "^20.3.11",
    "@angular/platform-browser": "^20.3.11",
    "@angular/platform-browser-dynamic": "^20.3.11",
    "@angular/platform-server": "^20.3.11",
    "@angular/router": "^20.3.11",
    "@angular/service-worker": "^20.3.11",
    "@angular/ssr": "^20.3.10",
    "@fortawesome/angular-fontawesome": "^3.0.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "axios": "^1.6.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "http-proxy-middleware": "^3.0.5",
    "javascript-obfuscator": "^5.0.1",
    "ngx-toastr": "^19.1.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.10",
    "@angular-devkit/core": "^20.3.10",
    "@angular-devkit/schematics": "^20.3.10",
    "@angular/cli": "^20.3.10",
    "@angular/compiler-cli": "^20.3.11",
    "@compodoc/compodoc": "^1.2.0",
    "@eslint/js": "^9.39.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "22.4.2",
    "@nx/express": "^22.4.4",
    "@nx/jest": "22.4.4",
    "@nx/js": "22.4.4",
    "@nx/nest": "^22.4.2",
    "@nx/node": "22.4.4",
    "@nx/web": "22.4.4",
    "@nx/webpack": "22.4.4",
    "@nx/workspace": "22.4.2",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@schematics/angular": "^20.3.10",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/jasmine": "~5.1.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.9",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jasmine-core": "~5.12.1",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
